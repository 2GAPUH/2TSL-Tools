{
  "manifest_version": 3,
  "name": "2TSL toolbox",
  "version": "0.8.0",
  "description": "Набор инструментов для повышения эффективности работы: управление шаблонами, навигация между системами, напоминания и автоматизация рутинных задач.",
  "permissions": ["storage", "tabs", "notifications", "alarms", "identity", "identity.email"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Управление расширением"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/icon.png", "icons/icon_white.png",
        "icons/edit.png", "icons/edit_white.png",
        "icons/delete.png", "icons/delete_white.png",
        "icons/copy.png", "icons/copy_white.png",
        "icons/paste.png", "icons/paste_white.png",
        "icons/folder.png", "icons/folder_white.png",
        "icons/clipboard.png", "icons/clipboard_white.png",
        "icons/clock.png", "icons/clock_white.png",
        "icons/settings.png", "icons/settings_white.png",
        "icons/message-circle-plus.png", "icons/message-circle-plus_white.png",
        "icons/save.png", "icons/save_white.png",
        "icons/cancel.png", "icons/cancel_white.png",
        "icons/zap.png", "icons/zap_white.png",
        "icons/palette.png", "icons/palette_white.png",
        "icons/check-check.png", "icons/check-check_white.png"
      ],
      "matches": ["https://omnichat.rt.ru/*", "https://www.ttm.rt.ru/*", "https://bzbti.rt.ru/*", "https://epd.rt.ru/*", "http://10.77.19.50/*", "http://10.144.39.131/*", "http://10.160.191.178/*"]
    },
    {
      "resources": ["argus-dark.css"],
      "matches": [
        "https://argus.rt.ru/*",
        "https://volga.argus.rt.ru/*",
        "https://south.argus.rt.ru/*",
        "https://sz.argus.rt.ru/*"
      ]
    },
    {
      "resources": ["axiros-dark.css"],
      "matches": [
        "http://acs-tr69.sz.rt.ru:4673/*",
        "http://tr069.south.rt.ru:9673/*",
        "http://10.82.16.11:9673/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://omnichat.rt.ru/*"],
      "js": [
        "omnichat/namespace.js",
        "omnichat/state.js",
        "omnichat/constants.js",
        "omnichat/utils.js",
        "omnichat/draft-insert.js",
        "omnichat/ttm-links.js",
        "omnichat/templates-modal.js",
        "omnichat/init.js",
        "content-accounting.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.ttm.rt.ru/*"],
      "js": ["content-ttm.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://bzbti.rt.ru/vip/ispolzovanie-assistenta/*"],
      "js": ["content-form.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://epd.rt.ru/stb-events/*"],
      "js": ["content-grafana.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://epd.rt.ru/customers/*"],
      "js": ["content-epd-mac.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://10.77.19.50/stb_ssh/*",
        "http://10.144.39.131/stb_ssh/*",
        "http://10.160.191.178/stb_ssh/*"
      ],
      "js": ["content-ssh.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://onymaweb.south.rt.ru/*"],
      "js": ["content-onyma.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://sipal.sz.rt.ru/*"],
      "js": ["content-sipal.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://volgahelp.ru/tag_api/comments/*"],
      "js": ["content-volgahelp.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://argus.rt.ru/*",
        "https://volga.argus.rt.ru/*",
        "https://south.argus.rt.ru/*",
        "https://sz.argus.rt.ru/*"
      ],
      "js": ["content-argus-theme.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "http://acs-tr69.sz.rt.ru:4673/*",
        "http://tr069.south.rt.ru:9673/*",
        "http://10.82.16.11:9673/*"
      ],
      "js": ["content-axiros-theme.js"],
      "run_at": "document_start"
    }
  ],
  "host_permissions": [
    "https://omnichat.rt.ru/*",
    "https://www.ttm.rt.ru/*",
    "https://bzbti.rt.ru/*",
    "https://epd.rt.ru/*",
    "http://10.77.19.50/*",
    "http://10.144.39.131/*",
    "http://10.160.191.178/*",
    "https://onymaweb.south.rt.ru/*",
    "http://sipal.sz.rt.ru/*",
    "https://script.google.com/*",
    "https://volgahelp.ru/*",
    "https://argus.rt.ru/*",
    "https://volga.argus.rt.ru/*",
    "https://south.argus.rt.ru/*",
    "https://sz.argus.rt.ru/*",
    "http://acs-tr69.sz.rt.ru:4673/*",
    "http://tr069.south.rt.ru:9673/*",
    "http://10.82.16.11:9673/*",
    "https://api.maclookup.app/*"
  ]
}
